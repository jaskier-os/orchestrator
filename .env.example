# Orchestrator configuration. Copy to .env and fill in values.
# Every peer service is a configurable host/URL; all default to localhost so the
# orchestrator runs standalone with no VPN and no certificates.

# Port the orchestrator HTTP + WebSocket server listens on.
PORT=10001

# Shared auth key required on inbound API/WS requests AND sent to the
# Communicator as a Bearer token. Generate your own; do NOT reuse any example.
API_KEY=change-me

# Communicator (LLM API gateway) base URL.
COMMUNICATOR_URL=http://localhost:10000

# Default LLM model alias passed to the Communicator.
LLM_MODEL=sonnet

# Text-to-speech service URLs.
TTS_URL=http://localhost:10007
PIPER_TTS_URL=http://localhost:10013

# TTS routing mode. 'language-split' (default) detects EN/RU per segment and
# routes English -> Kokoro (TTS_URL), Russian -> TeraTTS (PIPER_TTS_URL), mixed
# -> per-segment concat. 'teratts' sends all text to TeraTTS (PIPER_TTS_URL),
# which pronounces English via Russian phonemes.
TTS_ROUTING_MODE=language-split

# Speech-to-text / transcription services.
TRANSCRIBER_URL=http://localhost:10003
TRANSCRIBER_WS_URL=ws://localhost:10003/ws/stream
ANTHROPIC_STT_URL=http://localhost:10016

# Translation service.
TRANSLATOR_URL=http://localhost:10015

# ReID analytics service.
REID_ANALYTICS_URL=http://localhost:3400

# Enable speaker verification (true/false).
SPEAKER_VERIFICATION_ENABLED=false

# Session lifecycle tuning (milliseconds / token thresholds).
SESSION_TIMEOUT_MS=600000
COMPACTION_THRESHOLD=180000
RC_SESSION_TIMEOUT_MS=43200000

# On-disk locations for chat / copilot history (created if missing).
CHAT_HISTORY_DIR=./data/chat-history
COPILOT_HISTORY_DIR=./data/copilot-history

# MongoDB connection string.
MONGO_URL=mongodb://localhost:27017

# Public host:port that remote agents (pc-agent) should dial back for
# remote-control sessions. If unset, the orchestrator falls back to the inbound
# request Host header. Set this in production to avoid host-header injection.
# Example: ORCHESTRATOR_PUBLIC_HOST=orchestrator.example.com:8443
# ORCHESTRATOR_PUBLIC_HOST=

# OPTIONAL TLS. The SDK BaseAgent connects to the orchestrator over plain
# ws:// by default. To use wss:// with a private CA, point this at a CA bundle
# file; if unset or the file is missing, the agent stays on a plain connection
# and does NOT crash. Never commit the cert file itself.
# NODE_EXTRA_CA_CERTS=/absolute/path/to/ca.pem
